// SOS Runtime — Firestore security rules.
//
// All client SDK access is BLOCKED. SOS Runtime's only valid
// caller path is the Cloud Run service account, which uses the
// admin SDK and bypasses these rules entirely. This file exists to
// guarantee that NO public / authenticated-user-from-WP client can
// reach the data directly — every read and write must go through
// the FastAPI surface.
//
// Apply with:
//   gcloud firestore deploy firestore.rules

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default: deny everything that isn't matched below.
    match /{document=**} {
      allow read, write: if false;
    }

    // The three SOS collections are admin-SDK-only.
    match /sessions/{sessionId} {
      allow read, write: if false;
    }
    match /events/{eventId} {
      allow read, write: if false;
    }
    match /states/{userId} {
      allow read, write: if false;
    }
  }
}
