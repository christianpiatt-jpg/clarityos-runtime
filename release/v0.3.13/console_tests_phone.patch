+    "Operator trajectory is steady.";
+  const operatorDiff = `=== Operator Diff ===\n\n[Operator Diff Summary]\n${dsum}`;
+
+  const mp = `=== Operator Meta-Pattern ===\n\n[Meta-Pattern Level]\n${o.metaPattern ?? "HIGH"}`;
