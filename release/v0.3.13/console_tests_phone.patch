+        runIndex:        1,
+        hasCrit:         true,
+        hasVolatile:     true,
+        critCount:       1,
+        volatilityCount: 1,
+        driftCount:      0,
+        upperCount:      0,
+        pressureLabel:   "medium",
+        pressureSum:     14,
+        pressureBand:    "-=",
+      }),
+    ];
+    const out = buildStructuralGovernance(sigs, NO_DIFFS, "");
