+    const sigs = [
+      makeSig({ runIndex: 0 }),
+      makeSig({
+        runIndex:        1,
+        hasCrit:         true,
+        hasVolatile:     true,
+        critCount:       2,
+        volatilityCount: 2,
+        pressureLabel:   "medium",
