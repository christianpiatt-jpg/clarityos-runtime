+    // MEDIUM-HIGH score, projection bumps to HIGH so the trajectory
+    // actually moves.
+    const sigs = [
+      makeSig({
+        runIndex:        0,
+        hasVolatile:     true,
+        volatilityCount: 2,
+      }),
+      makeSig({
+        runIndex:        1,
+        hasVolatile:     true,
+        volatilityCount: 1,
+      }),
