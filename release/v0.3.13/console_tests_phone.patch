+    runIndex:        0,
+    regime:          "L",
+    pressureSum:     0,
+    fingerprint:     "L--",
+    signatureToken:  "L-",
+    pressureBand:    "--",
+    pressureLabel:   "low",
+    hasCrit:         false,
+    hasUpper:        false,
