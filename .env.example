# PASS-6 Phase C — Environment-variable template.
#
# Copy this file to ``.env`` and fill in the values for local
# development. ``.env`` MUST NOT be committed (the project's
# ``.gitignore`` excludes it). In production, every secret in this
# file is mounted from Google Secret Manager; the workflow in
# .github/workflows/deploy.yml documents the wiring.
#
# Every value below is a placeholder. None of them are real secrets.

# =============================================================================
# REQUIRED — vault master secret
# =============================================================================
# The PBKDF2 master input. Missing or empty causes ``memory_vault._secret()``
# to raise ``RuntimeError`` at the first ``vault_init`` / ``vault_put`` —
# the runtime refuses to fall back to a default key (see INV-V8).
CLARITYOS_VAULT_SECRET=replace-me-with-a-strong-random-string

# =============================================================================
# OPTIONAL — vault backend selection
# =============================================================================
# Storage backend for memory_vault. Accepted values:
#   "mock"      — in-memory (default when CLARITYOS_BACKEND=memory)
#   "fs"        — one JSON file per user under CLARITYOS_VAULT_DIR
#   "sqlite"    — single SQLite DB at CLARITYOS_VAULT_DB
#   "firestore" — production (one document per entry; Cloud Run durable)
# Leave blank to fall through to the default per CLARITYOS_BACKEND.
CLARITYOS_VAULT_BACKEND=
CLARITYOS_VAULT_DIR=
CLARITYOS_VAULT_DB=

# =============================================================================
# OPTIONAL — plaintext vault mode (DEV ONLY)
# =============================================================================
# Only the EXPLICIT string "true" (case-insensitive, whitespace-trimmed)
# enables plaintext mode. Any other value — including the legacy "1" /
# "yes" — leaves encryption ON (PASS-4 FIX-P3). When set to "true" the
# runtime emits exactly one high-severity warning per process startup.
# DO NOT set this in production.
CLARITYOS_VAULT_PLAINTEXT=

# =============================================================================
# OPTIONAL — PBKDF2 iteration count override
# =============================================================================
# Default is 100,000 (DEFAULT_PBKDF2_ITERATIONS). Lowering this in
# production weakens key derivation; tests pin it to the default.
CLARITYOS_VAULT_PBKDF2=

# =============================================================================
# REQUIRED IN PROD — admin / founder bootstrap
# =============================================================================
# Bootstrap admin user for the first deployment. The password is
# required at startup when CLARITYOS_BOOTSTRAP_PASSWORD_REQUIRED=1 (the
# default in production).
CLARITYOS_ADMIN_USER=admin
CLARITYOS_ADMIN_PASSWORD=replace-me-strong-bootstrap-password
CLARITYOS_BOOTSTRAP_PASSWORD_REQUIRED=1

# =============================================================================
# OPTIONAL — storage + invite bookkeeping
# =============================================================================
# In-memory vs Firestore for users / sessions / library / etc.
#   "memory"    — process-local mocks (tests + local dev)
#   "firestore" — production
CLARITYOS_BACKEND=memory

# Library blob storage (GCS bucket + prefix).
CLARITYOS_LIBRARY_BUCKET=
CLARITYOS_LIBRARY_PREFIX=

# Invite-only mode.
CLARITYOS_INVITE_ONLY=0
CLARITYOS_INVITE_BASE_URL=
CLARITYOS_INVITE_TTL_DAYS=30

# CORS origins (comma-separated list).
CLARITYOS_CORS_ORIGINS=

# Session TTL in seconds.
CLARITYOS_SESSION_TTL=86400

# Rate-limit knobs (default capacity per window).
CLARITYOS_RATE_LIMIT_ENFORCE=1
CLARITYOS_RATE_LIMIT_CAPACITY=
CLARITYOS_RATE_LIMIT_WINDOW_S=

# =============================================================================
# OPTIONAL — billing (Stripe)
# =============================================================================
# Mode: "mock" (default for dev + CI), "stripe" (production live), or
# "stripe_test" (sandbox keys).
CLARITYOS_BILLING_MODE=mock

# Auto-confirm mock-mode intents — set to "0" to drive the async flow
# (mock-mode renewal-status tests use this).
CLARITYOS_MOCK_AUTO_CONFIRM=1

# Stripe keys (production only).
CLARITYOS_STRIPE_MODE=
CLARITYOS_STRIPE_SECRET_KEY=
CLARITYOS_STRIPE_WEBHOOK_SECRET=

# Renewal scheduler tick (default 86400 = once per day).
CLARITYOS_RENEWAL_TICK_SECONDS=

# =============================================================================
# OPTIONAL — model-provider keys (BD3 router)
# =============================================================================
# Without these keys, the provider handlers fall back to the deterministic
# mock payload (the v44 mock contract). Setting any of these flips the
# corresponding provider to "configured=True" in get_model_status().
CLARITYOS_OPENAI_KEY=
CLARITYOS_ANTHROPIC_KEY=
CLARITYOS_GEMINI_KEY=
CLARITYOS_XAI_KEY=

# Path to a local model file (GGUF / ONNX). When set, the local
# provider runs through local_model_runtime instead of the mock.
CLARITYOS_LOCAL_MODEL_PATH=

# =============================================================================
# OPTIONAL — schedulers + ops
# =============================================================================
# Set to "1" in tests + CI to suppress the macro-ELINS scheduler boot.
CLARITYOS_DISABLE_MACRO_SCHEDULER=0

# Logging level (defaults to INFO in production, WARNING in CI).
CLARITYOS_LOG_LEVEL=INFO

# ELINS / evidence directories.
CLARITYOS_ELINS_JSON_PATH=
CLARITYOS_EVIDENCE_DIR=

# Email / SMTP (operator reports).
CLARITYOS_SMTP_HOST=
CLARITYOS_SMTP_TO_OVERRIDE=
