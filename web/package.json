{
  "name": "clarityos-web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:embed": "vite build --mode embed",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "contracts:gen": "node scripts/gen-contract-schema.mjs",
    "contracts:check": "node scripts/gen-contract-schema.mjs && git diff --exit-code src/contracts/webSurfaceV0_2.schema.json",
    "assets:gen": "node scripts/gen-asset-manifest.mjs",
    "assets:check": "node scripts/gen-asset-manifest.mjs && git diff --exit-code assets/v0.2/manifest.json"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
